# --- Server ---
PORT=5050

# Everything below is only needed for REAL outbound calls (Twilio + OpenAI).
# Leave it blank and use "Run mock call (free)" in the UI to test with $0.

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17
OPENAI_TEXT_MODEL=gpt-4o-mini

# --- Twilio ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# Public host Twilio/ngrok can reach (no https://, no trailing slash).
# Example: abcd-1234.ngrok-free.app
PUBLIC_HOSTNAME=your-ngrok-subdomain.ngrok-free.app
